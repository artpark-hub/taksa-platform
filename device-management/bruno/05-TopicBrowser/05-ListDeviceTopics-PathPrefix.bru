meta {
  name: List Device Topics (path prefix)
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/v1/devicemgmt/devices/{{device_id}}/topics/list
  body: json
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{console_bearer_token}}
}

body:json {
  {
    "deviceId": "{{device_id}}",
    "pageSize": 50,
    "pathPrefix": "Enterprise.Site.Line1.",
    "omitLastEvent": true,
    "text": "Temperature"
  }
}

tests {
  test('Status 200', function() {
    expect(res.getStatus()).to.equal(200);
  });

  test('Filtered count <= total', function() {
    const b = res.getBody();
    expect(b.filteredCount).to.be.at.most(b.totalCount);
  });
}
