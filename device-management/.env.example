# Taksa Platform DM Configuration
# Service: Device Management (DM)
# Follows taksa-deployments naming convention (TAKSA_DM_* prefix)
# All values can be overridden via environment variables (Docker pattern)

# Data persistence directory (use absolute path or relative to docker-compose.yml)
TAKSA_DM_DATA_DIR=./data

# API Server Configuration
TAKSA_DM_HTTP_PORT=8000
TAKSA_DM_GRPC_PORT=9000

# Logging Configuration
TAKSA_DM_LOG_LEVEL=debug
TAKSA_DM_LOG_FILE=/data/taksa-device-management.log

# For PostgreSQL (use TAKSA_PG_* from taksa-deployments):
TAKSA_DM_DATABASE_DRIVER=postgres
TAKSA_DM_DATABASE_SOURCE=postgres://user:password@localhost:5432/taksa_platform_dm?sslmode=disable

# Deployment Configuration (for device registration Docker command generation)
TAKSA_DM_BASE_URL=http://localhost:8000
TAKSA_DM_UMH_CORE_DOCKER_IMAGE=management.umh.app/oci/united-manufacturing-hub/umh-core:v0.43.17

# NATS cluster URLs (comma-separated) for auto-deployed UNS→NATS mirror on DCD login. Leave empty to disable.
# Example: nats://user:pass@nats.example.com:4222
TAKSA_DM_NATS_MIRROR_URLS=
